import { lazy, Suspense } from 'react';
import { createBrowserRouter, Navigate } from 'react-router-dom';
import { Spin } from 'antd';
import { ProtectedRoute } from '@/shared/components/auth/ProtectedRoute';

// 懒加载组件
const LoginPage = lazy(() =>
  import('@/features/auth/pages/LoginPage').then((m) => ({ default: m.LoginPage }))
);
const MainLayout = lazy(() =>
  import('@/shared/components/layouts/MainLayout').then((m) => ({ default: m.MainLayout }))
);
const DashboardPage = lazy(() =>
  import('@/features/dashboard/pages/DashboardPage').then((m) => ({ default: m.DashboardPage }))
);
const UserListPage = lazy(() =>
  import('@/features/rbac/user/pages/UserListPage').then((m) => ({ default: m.UserListPage }))
);
const PermissionListPage = lazy(() =>
  import('@/features/rbac/permission/pages/PermissionListPage').then((m) => ({
    default: m.PermissionListPage,
  }))
);
const RoleListPage = lazy(() =>
  import('@/features/rbac/role/pages/RoleListPage').then((m) => ({ default: m.RoleListPage }))
);
const MenuListPage = lazy(() =>
  import('@/features/rbac/menu/pages/MenuListPage').then((m) => ({ default: m.MenuListPage }))
);
const DictListPage = lazy(() =>
  import('@/features/dict/pages/DictListPage').then((m) => ({ default: m.DictListPage }))
);
const ConfigListPage = lazy(() =>
  import('@/features/config/pages/ConfigListPage').then((m) => ({ default: m.ConfigListPage }))
);
const NotificationListPage = lazy(() =>
  import('@/features/notification/pages/NotificationListPage').then((m) => ({
    default: m.NotificationListPage,
  }))
);
const FileList = lazy(() =>
  import('@/features/file/components/FileList').then((m) => ({ default: m.FileList }))
);
const TaskList = lazy(() =>
  import('@/features/task/components/TaskList').then((m) => ({ default: m.TaskList }))
);
const ApiAuthPage = lazy(() =>
  import('@/features/api-auth/pages/ApiAuthPage').then((m) => ({ default: m.ApiAuthPage }))
);

// 加载中组件
const PageLoading = () => (
  <div className="flex items-center justify-center min-h-screen">
    <Spin size="large" />
  </div>
);

// Suspense包装器
const withSuspense = (Component: React.LazyExoticComponent<React.ComponentType>) => (
  <Suspense fallback={<PageLoading />}>
    <Component />
  </Suspense>
);

/**
 * 路由配置
 *
 * 架构说明：
 * 1. 公开路由：不需要登录（如登录页）
 * 2. 受保护路由：需要登录（使用ProtectedRoute守卫）
 * 3. 权限路由：需要特定权限（ProtectedRoute + permissions参数）
 */
export const router = createBrowserRouter([
  // ========== 公开路由 ==========
  {
    path: '/login',
    element: withSuspense(LoginPage),
  },

  // ========== 受保护路由（需要登录）==========
  {
    path: '/',
    element: <ProtectedRoute />, // JWT认证守卫
    children: [
      {
        path: '',
        element: withSuspense(MainLayout), // 主布局
        children: [
          {
            index: true,
            element: <Navigate to="/dashboard" replace />,
          },
          {
            path: 'dashboard',
            element: withSuspense(DashboardPage),
          },

          // ========== 用户管理（需要user:read权限）==========
          {
            path: 'users',
            element: <ProtectedRoute permissions={['user:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(UserListPage),
              },
              // TODO: 用户详情页
              // {
              //   path: ':id',
              //   element: withSuspense(UserDetailPage),
              // },
            ],
          },

          // ========== 角色管理（需要role:read权限）==========
          {
            path: 'roles',
            element: <ProtectedRoute permissions={['role:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(RoleListPage),
              },
            ],
          },

          // ========== 权限管理（需要permission:read权限）==========
          {
            path: 'permissions',
            element: <ProtectedRoute permissions={['permission:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(PermissionListPage),
              },
            ],
          },

          // ========== 菜单管理（需要menu:read权限）==========
          {
            path: 'menus',
            element: <ProtectedRoute permissions={['menu:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(MenuListPage),
              },
            ],
          },

          // ========== 数据字典（需要dict:read权限）==========
          {
            path: 'dicts',
            element: <ProtectedRoute permissions={['dict:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(DictListPage),
              },
            ],
          },

          // ========== 系统配置（需要config:read权限）==========
          {
            path: 'configs',
            element: <ProtectedRoute permissions={['config:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(ConfigListPage),
              },
            ],
          },

          // ========== 通知系统（需要notification:read权限）==========
          {
            path: 'notifications',
            element: <ProtectedRoute permissions={['notification:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(NotificationListPage),
              },
            ],
          },

          // ========== 文件管理（需要file:read权限）==========
          {
            path: 'files',
            element: <ProtectedRoute permissions={['file:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(FileList),
              },
            ],
          },

          // ========== 任务调度（需要task:read权限）==========
          {
            path: 'tasks',
            element: <ProtectedRoute permissions={['task:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(TaskList),
              },
            ],
          },

          // ========== API认证（需要api-auth:read权限）==========
          {
            path: 'api-auth',
            element: <ProtectedRoute permissions={['api-auth:read']} />,
            children: [
              {
                index: true,
                element: withSuspense(ApiAuthPage),
              },
            ],
          },
        ],
      },
    ],
  },

  // ========== 404路由 ==========
  {
    path: '*',
    element: <Navigate to="/dashboard" replace />,
  },
]);
