# ========================================
# API Configuration
# ========================================

# Backend API base URL
VITE_API_URL=http://localhost:3000/api/v1

# ========================================
# Application Configuration
# ========================================

# Application title (displayed in browser tab)
VITE_APP_TITLE=home 管理后台

# ========================================
# Docker Runtime Configuration
# ========================================

# Nginx upstream for proxying /api and /uploads in the web container
API_UPSTREAM=http://host.docker.internal:3000

# ========================================
# Production Configuration Example
# ========================================

# For production deployment, create .env.production with:
# VITE_API_URL=/api/v1
# VITE_APP_TITLE=Your App Name
