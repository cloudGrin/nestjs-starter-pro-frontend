{
  "name": "home-web",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.19.0 || >=22.12.0",
    "pnpm": ">=9"
  },
  "description": "Frontend management console for home-admin.",
  "license": "MIT",
  "keywords": [
    "react",
    "typescript",
    "admin-dashboard",
    "frontend",
    "antd",
    "vite",
    "rbac",
    "zustand",
    "tanstack-query",
    "tailwindcss"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "api:check": "echo '请对照本地 api-docs.json 复核手写 API 服务类型'",
    "docker:build": "docker build -t home-web .",
    "docker:run": "docker run --rm -p 8080:80 -e API_UPSTREAM=http://host.docker.internal:3000 home-web"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.2",
    "@tanstack/query-persist-client-core": "^5.100.9",
    "@tanstack/query-sync-storage-persister": "^5.100.9",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "antd": "^5.29.3",
    "antd-mobile": "^5.42.3",
    "axios": "^1.16.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-router-dom": "^7.15.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vconsole": "^3.15.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@swc/core": "^1.15.33",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "4.1.5",
    "autoprefixer": "^10.5.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^16.5.0",
    "jsdom": "26.1.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^7.3.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "4.1.5"
  },
  "volta": {
    "node": "22.20.0",
    "pnpm": "10.3.0"
  }
}
